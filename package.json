{
	"name": "python-web-kernel-suede",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:pages": "BASE_PATH=/python-web-kernel-suede npm run build",
		"clean:pages": "find .worktrees/gh-pages -mindepth 1 ! -name .git ! -name .nojekyll -print -exec rm -rf {} +",
		"mv:pages": " mv build/* .worktrees/gh-pages/",
		"pages": "npm run build:pages && npm run clean:pages && npm run mv:pages && git -C .worktrees/gh-pages add . && git -C .worktrees/gh-pages commit -m 'Update pages' && git -C .worktrees/gh-pages push",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"devDependencies": {
		"@codingame/esbuild-import-meta-url-plugin": "^1.0.3",
		"@codingame/monaco-vscode-files-service-override": "~5.1.1",
		"@codingame/monaco-vscode-python-default-extension": "~5.1.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.1",
		"@typefox/pyright-browser": "^1.1.299",
		"@types/node": "^25.2.3",
		"dockview": "^4.13.1",
		"dockview-core": "^4.13.1",
		"jszip": "^3.10.1",
		"monaco-editor": "npm:@codingame/monaco-vscode-editor-api@~5.1.1",
		"monaco-editor-wrapper": "~5.1.1",
		"monaco-languageclient": "~8.4.0",
		"svelte": "^5.49.2",
		"svelte-check": "^4.3.6",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"vite-plugin-static-copy": "^3.2.0",
		"vitest": "^4.0.18",
		"vscode": "npm:@codingame/monaco-vscode-api@~5.1.1",
		"vscode-languageclient": "~9.0.1",
		"vscode-languageserver-protocol": "^3.17.5",
		"y-monaco": "^0.1.6",
		"y-protocols": "^1.0.7"
	},
	"dependencies": {
		"@jupyterlab/nbformat": "^4.5.4",
		"katex": "^0.16.28",
		"nanoid": "^5.1.6",
		"pyodide": "^0.29.3",
		"vite": "^7.3.1"
	}
}
